# Copy this file to .env for local development.
# In production (AWS App Runner), set these as environment variables/secrets
# in the App Runner service configuration instead of shipping a .env file.

# Your Anthropic API key. Never commit the real value.
GEMINI_API_KEY=your_google_ai_studio_api_key

# Port the Express server listens on. App Runner injects PORT itself,
# but we default to 8080 to match App Runner's default expectation.
PORT=8080

# Comma-separated list of origins allowed to call the API when the
# frontend is NOT served from the same origin (e.g. local dev with
# Vite on a different port). Not needed in production since the
# backend serves the built frontend itself.
ALLOWED_ORIGINS=http://localhost:5173
